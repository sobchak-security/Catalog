{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sobchak-security/Catalog/raw/main/schema/manifest.schema.json",
  "title": "CatalogManifest",
  "description": "Signed top-level manifest for an RF Buddy Catalog release.",
  "type": "object",
  "required": [
    "schemaVersion",
    "revision",
    "modelCount",
    "totalBytes",
    "entries",
    "signerKeyID",
    "signature"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "revision": {
      "type": "object",
      "required": ["number", "publishedAt"],
      "additionalProperties": false,
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1,
          "description": "Monotonically increasing release number."
        },
        "publishedAt": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 UTC timestamp of publication."
        }
      }
    },
    "modelCount": {
      "type": "integer",
      "minimum": 0
    },
    "totalBytes": {
      "type": "integer",
      "minimum": 0,
      "description": "Sum of all individual model file sizes in bytes."
    },
    "entries": {
      "type": "array",
      "items": { "$ref": "#/$defs/entry" }
    },
    "signerKeyID": {
      "type": "string",
      "minLength": 1,
      "description": "Key identifier matching catalog.config.yml signing.current_key_id."
    },
    "signature": {
      "type": "string",
      "description": "Ed25519 signature over canonical-JSON of this object with this field set to empty string. Prefixed 'ed25519-' followed by base64url."
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": ["id", "revisionAdded", "revisionUpdated", "contentHash", "bytes", "path"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid"
        },
        "revisionAdded": {
          "type": "integer",
          "minimum": 1
        },
        "revisionUpdated": {
          "type": "integer",
          "minimum": 1
        },
        "contentHash": {
          "type": "string",
          "pattern": "^sha256-[A-Za-z0-9+/=]{44}$",
          "description": "SHA-256 of the canonical-JSON bytes of the model file, base64-encoded."
        },
        "bytes": {
          "type": "integer",
          "minimum": 0
        },
        "path": {
          "type": "string",
          "pattern": "^cameras/[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}\\.json$"
        }
      }
    }
  }
}
